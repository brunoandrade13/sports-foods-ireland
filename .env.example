# Supabase: URL e chave (admin/backend)
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- Conexão para scripts (npm run supabase:financial-analytics) ----
# Uma das opções abaixo (a primeira que funcionar é usada).

# Opção A — Session pooler: Supabase → Connect → "Session pooler" → copiar URI.
# (substituir [YOUR-PASSWORD]; $→%24, +→%2B, !→%21)
# SUPABASE_DB_POOLER_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Opção B — Token de acesso (recomendado para scripts sem browser): https://supabase.com/dashboard/account/tokens → criar token.
# O script descobre a região do projeto e liga ao pooler correto.
SUPABASE_ACCESS_TOKEN=

# Opção C — Direct (porta 5432). Funciona em redes com IPv6; senão use A ou B.
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
